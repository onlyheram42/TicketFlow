<UserControl x:Class="TicketFlow.Desktop.Views.TicketDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000" Background="#f0f2f5">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Back" Command="{Binding BackToListCommand}" 
                    Background="Transparent" BorderThickness="0" Foreground="#0366d6" FontWeight="SemiBold" FontSize="16" Cursor="Hand" Margin="0,0,20,0"/>

            <TextBlock Grid.Column="1" Text="{Binding Ticket.Subject}" FontSize="28" FontWeight="SemiBold" Foreground="#24292e" VerticalAlignment="Center"/>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Details & Comments -->
            <ScrollViewer Grid.Column="0" Margin="0,0,20,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Ticket Info Card -->
                    <Border Background="White" BorderBrush="#e1e4e8" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="{Binding Ticket.CreatedByName, StringFormat='Opened by \{0\}'}" Foreground="#586069"/>
                                <TextBlock Grid.Column="1" Text="{Binding Ticket.CreatedAt, StringFormat=' on MMM dd, yyyy HH:mm'}" Foreground="#586069"/>
                                <TextBlock Grid.Column="2" Text="{Binding Ticket.TicketNumber}" FontWeight="SemiBold" Foreground="#24292e"/>
                            </Grid>

                            <TextBlock Text="{Binding Ticket.Description}" TextWrapping="Wrap" FontSize="14" Foreground="#24292e" LineHeight="20"/>
                        </StackPanel>
                    </Border>

                    <!-- Comments Section -->
                    <TextBlock Text="Comments" FontSize="18" FontWeight="SemiBold" Foreground="#24292e" Margin="0,0,0,10"/>
                    
                    <ItemsControl ItemsSource="{Binding Ticket.Comments}" Margin="0,0,0,20">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding IsInternal, Converter={StaticResource InternalCommentBgConverter}}" 
                                        BorderBrush="#e1e4e8" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" Foreground="#24292e" Margin="0,0,10,0"/>
                                                <Border Background="#fffbdd" BorderBrush="#d9d0a5" BorderThickness="1" CornerRadius="3" Padding="4,1" 
                                                        Visibility="{Binding IsInternal, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="Internal Note" FontSize="11" Foreground="#735c0f" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding CreatedAt, StringFormat='MMM dd HH:mm'}" Foreground="#586069" FontSize="12"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Comment}" TextWrapping="Wrap" Foreground="#24292e"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Add Comment Box -->
                    <Border Background="#f6f8fa" BorderBrush="#e1e4e8" BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Add a comment" FontWeight="SemiBold" Foreground="#24292e" Margin="0,0,0,10"/>
                            
                            <TextBox Text="{Binding NewComment, UpdateSourceTrigger=PropertyChanged}" 
                                     TextWrapping="Wrap" AcceptsReturn="True" Height="100" Padding="8" BorderBrush="#e1e4e8" BorderThickness="1" Margin="0,0,0,10"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" Content="Make internal (Admin only)" IsChecked="{Binding IsInternalComment}" 
                                          Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}" VerticalAlignment="Center" Foreground="#586069"/>

                                <Button Grid.Column="1" Content="Comment" Command="{Binding AddCommentCommand}" 
                                        Background="#2ea44f" Foreground="White" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right Column: Sidebar (Status, Assignment, History) -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#cb2431" TextWrapping="Wrap" 
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" Margin="0,0,0,15"/>

                    <!-- Admin Controls (Only visible to Admin) -->
                    <Border Background="White" BorderBrush="#e1e4e8" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Admin Controls" FontWeight="SemiBold" Foreground="#24292e" Margin="0,0,0,15"/>

                            <TextBlock Text="Assignee" Foreground="#586069" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" ItemsSource="{Binding AdminUsers}" SelectedItem="{Binding SelectedAdmin}" 
                                          DisplayMemberPath="FullName" Margin="0,0,5,0" Padding="5"/>
                                <Button Grid.Column="1" Content="Assign" Command="{Binding AssignTicketCommand}" Padding="8,4" Background="#fafbfc" BorderBrush="#e1e4e8" Cursor="Hand"/>
                            </Grid>

                            <TextBlock Text="Status" Foreground="#586069" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" 
                                          Margin="0,0,5,0" Padding="5"/>
                                <Button Grid.Column="1" Content="Update" Command="{Binding UpdateStatusCommand}" Padding="8,4" Background="#fafbfc" BorderBrush="#e1e4e8" Cursor="Hand"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- User Status Viewer (Visible to non-admins) -->
                    <Border Background="White" BorderBrush="#e1e4e8" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20"
                            Visibility="{Binding IsAdmin, Converter={StaticResource InverseBooleanConverter}}">
                        <StackPanel>
                            <TextBlock Text="Ticket Info" FontWeight="SemiBold" Foreground="#24292e" Margin="0,0,0,10"/>
                            
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Status:" Foreground="#586069"/>
                                <TextBlock Grid.Column="1" Text="{Binding Ticket.Status}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Priority:" Foreground="#586069"/>
                                <TextBlock Grid.Column="1" Text="{Binding Ticket.Priority}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Assignee:" Foreground="#586069"/>
                                <TextBlock Grid.Column="1" Text="{Binding Ticket.AssignedToName, TargetNullValue='Unassigned'}" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- History Timeline -->
                    <Border Background="White" BorderBrush="#e1e4e8" BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel>
                            <TextBlock Text="History" FontWeight="SemiBold" Foreground="#24292e" Margin="0,0,0,15"/>

                            <ItemsControl ItemsSource="{Binding Ticket.History}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Bullet point -->
                                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#d1d5da" VerticalAlignment="Top" Margin="0,6,0,0"/>
                                            
                                            <StackPanel Grid.Column="1">
                                                <TextBlock TextWrapping="Wrap" Foreground="#24292e">
                                                    <Run Text="{Binding ChangedByName}" FontWeight="SemiBold"/>
                                                    <Run Text=" changed status to "/>
                                                    <Run Text="{Binding NewStatus}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding ChangedAt, StringFormat='MMM dd, yyyy HH:mm'}" Foreground="#586069" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
