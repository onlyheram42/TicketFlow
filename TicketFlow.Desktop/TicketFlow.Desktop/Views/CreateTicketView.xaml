<UserControl x:Class="TicketFlow.Desktop.Views.CreateTicketView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800" Background="White">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Create New Ticket" FontSize="28" FontWeight="Light" Foreground="#24292e" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="600" HorizontalAlignment="Left">
                <TextBlock Text="Subject" Foreground="#586069" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="10" Margin="0,0,0,20" FontSize="14" BorderBrush="#e1e4e8" BorderThickness="1"/>

                <TextBlock Text="Priority" Foreground="#586069" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding SelectedPriority}" 
                          Padding="10" Margin="0,0,0,20" FontSize="14" BorderBrush="#e1e4e8" BorderThickness="1"/>

                <TextBlock Text="Description" Foreground="#586069" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                         TextWrapping="Wrap" AcceptsReturn="True" Height="200" VerticalScrollBarVisibility="Auto"
                         Padding="10" Margin="0,0,0,20" FontSize="14" BorderBrush="#e1e4e8" BorderThickness="1"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0">
            <Button Content="Submit Ticket" Command="{Binding CreateTicketCommand}" 
                    Background="#2ea44f" Foreground="White" FontWeight="Bold" Padding="20,10" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"/>
            
            <Button Content="Cancel" Command="{Binding CancelCommand}" 
                    Background="#fafbfc" Foreground="#24292e" FontWeight="SemiBold" BorderBrush="#e1e4e8" Padding="20,10" Cursor="Hand"/>
                    
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#cb2431" FontWeight="SemiBold" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
